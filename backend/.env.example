# Kavach Backend Environment Variables

# Application
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://kavach:kavach@localhost:5432/kavach

# Security
JWT_SECRET=your-secret-key-change-in-production

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# NVIDIA NIM API
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_NIM_API_KEY_BACKUP=your_nvidia_nim_api_key_backup_here

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# File Storage
UPLOAD_DIR=./uploads
PDF_DIR=./uploads/pdf
DOCX_DIR=./uploads/docx